      "enabled": true,
      "windowSize": 8,
      "threshold": 3
    },
    "toolArgumentRepair": {
      "maxStringBytes": 524288
    }
  },
  "capabilities": {
    "mcp": {
      "enabled": true,
      "servers": {
        "gui_schedule": {
          "enabled": true,
          "transport": "stdio",
          "command": "/deepseek-gui",
          "args": [
            "/resources/app.asar/out/main/claw-schedule-mcp-node-entry.js",
            "--gui-schedule-mcp-server",
            "--base-url",
            "http://127.0.0.1:8788"
          ],
          "env": {
            "ELECTRON_RUN_AS_NODE": "1"
          },
          "trustScope": "user",
          "timeoutMs": 5000
        }
      },
      "search": {
        "enabled": true,
        "mode": "auto",
        "autoThresholdToolCount": 24,
        "topKDefault": 5,
        "topKMax": 10,
        "minScore": 0.15,
        "bm25": {
          "k1": 1.2,
          "b": 0.75
        }
      }
    },
    "web": {
      "enabled": true,
      "fetchEnabled": true,
      "searchEnabled": false,
      "allowDomains": [],
      "denyDomains": []
    },
    "skills": {
      "enabled": true,
      "roots": [
        "~/.agents/skills",
        "~/.codex/plugins/cache/openai-primary-runtime/documents/26.601.10930/skills",
        "~/.codex/plugins/cache/openai-primary-runtime/presentations/26.601.10930/skills",
        "~/.codex/plugins/cache/openai-curated/figma/d947469e/skills",
        "~/.codex/plugins/cache/openai-primary-runtime/spreadsheets/26.601.10930/skills",
        "~/.codex/plugins/cache/openai-bundled/chrome/0.1.7/skills"
      ],
      "legacySkillMd": true
    },
    "attachments": {
      "enabled": true,
      "maxImageBytes": 5242880,
      "maxImageDimension": 4096,
      "allowedMimeTypes": [
        "image/png",
        "image/jpeg",
        "image/webp"
      ],
      "textFallbackMaxBase64Bytes": 524288,
      "textFallbackMaxImageDimension": 1280,
      "textFallbackPreferredMimeType": "image/webp"
    }
  }
